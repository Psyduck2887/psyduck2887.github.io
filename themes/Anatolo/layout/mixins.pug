mixin make_post(item, is_detail)
  .post.animated
    .post-title
      h3
        if is_detail
          a= item.title
        else
          a(href=url_for(item.path))= item.title
    if is_detail
      .post-content
        p!= item.content
    else
      //- List card: first body image → title + 16:9 cover only; else keep text summary.
      - var coverSrc = null;
      //- Prefer full markdown so a `<!-- more -->` before the image does not hide the cover.
      - var mdForCover = String(item._content || item.raw || '');
      - var coverFromMd = mdForCover.match(/!\[[^\]]*\]\(([^)\s]+)(?:\s+"[^"]*")?\)/);
      - if (coverFromMd) coverSrc = coverFromMd[1];
      - if (!coverSrc)
        - var htmlForCover = String(item.content || '');
        - var coverFromHtml = htmlForCover.match(/<img[^>]+src=["']([^"']+)["']/i);
        - if (coverFromHtml) coverSrc = coverFromHtml[1];
      //- Absolute http(s)/protocol-relative URLs must not go through url_for.
      - var coverHref = null;
      - if (coverSrc)
        - if (/^(https?:)?\/\//i.test(coverSrc) || /^data:/i.test(coverSrc))
          - coverHref = coverSrc;
        - else
          - coverHref = url_for(coverSrc);
      .post-content
        if coverHref
          a.post-cover(href=url_for(item.path), title=item.title)
            img(src=coverHref, alt=item.title, loading="lazy")
        else if theme.useSummary
          if item.summary
            p!= item.summary
          else
            - var summary = item.excerpt || item.content;
            p!= truncate(strip_html(summary), { length: 160 })
        else
          .card
            if item.excerpt
              p!= item.excerpt
            else
              p!= item.summary || item.content
    .post-footer
      if is_detail
        if (item.copyright || theme.copyright.show) && item.copyright !== 'disabled'
          if theme.copyright.show_author || item.author
            .tip!= (item.copyright || theme.copyright.default) + "<br>" + __("author") + ": " + (item.author || theme.author)
          else
            .tip!= item.copyright || theme.copyright.default
      .meta
        .info
          if is_current('about')
            span
          else if is_current('guestbook')
            span
          else
            i.fa.fa-sun-o
            span.date= date(item.date, "YYYY-MM-DD")
            if item.categories
              each cat in item.categories.sort('posts').data
                a.tag(href=config.root + cat.path, title=cat.name)= cat.name + " "
            if item.tags
              each tag in item.tags.sort('posts').data
                i.fa.fa-tag
                a.tag(href=config.root + tag.path, title=tag.name)= tag.name + " "

            span
              - var words = word_count(item.content);
              - var needtime = duration((words / 300.0) * 60, "seconds");
              - var timestr = (time(needtime, "m") == "0" ? "" : time(needtime, "m") + __("time.minu")) + time(needtime, "s") + __("time.senc");
              = __("article.about") + words + __("article.words") + ", " + timestr + __("article.read")

mixin make_pager
  - var prev = page.prev_link;
  - var next = page.next_link;
  .pagination
    ul.clearfix
      if page.prev
        li.pre.pagbuttons
          a.btn(role="navigation", href=url_for(prev))= __("prev")
      if page.next
        li.next.pagbuttons
          a.btn(role="navigation", href=url_for(next))= __("next")

mixin postList
  .archive
    - var year = 0;
    - var change = false;
    - var firstYear = true;
    each item in page.posts.data
      - var itemYear = date(item.date, "YYYY") - 0;
      - change = year !== itemYear;
      - year = change ? itemYear : year;
      if change
        if firstYear
          | <div class="listing-title">
          != year
          | </div><ul class="listing">
          - firstYear = false;
        else
          | </ul><div class="listing-title">
          != year
          | </div><ul class="listing">

      .listing-item
        .listing-post
          a(href=url_for(item.path), title=item.title)= item.title
          .post-time
            span.date= date(item.date, "MM-DD")
